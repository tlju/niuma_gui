TodosPage {
    background-color: #f5f6fa;
}

TodosPage QFrame[class="toolbar"] {
    background-color: #ffffff;
    border: 1px solid #e9ecef;
    border-radius: 8px;
    padding: 8px 12px;
}

TodosPage QTableWidget {
    background-color: #ffffff;
    border: 1px solid #dee2e6;
    border-radius: 6px;
}

TodosPage QTableWidget::item {
    padding: 6px 4px;
}
