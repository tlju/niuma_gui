SystemParamsPage QFrame {
    background-color: #f8f9fa;
    border-radius: 8px;
    padding: 8px;
}

SystemParamsPage QTableWidget {
    background-color: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
}

SystemParamsPage QTableWidget::item {
    padding: 8px 4px;
    height: 40px;
}
